# Opentext SDP MCP Server
OCTANE_BASE_URL=http://localhost:8080
API_KEY=your-opentext-sdp-api-key-here

# Opentext SDP context (sharedSpaceId/workspaceId)
DEFAULT_SHARED_SPACE_ID=1001
DEFAULT_WORKSPACE_ID=1002

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# App binding
A2A_HOST=0.0.0.0
A2A_PORT=9000

# Agent identity & OAuth2 (published in the AgentCard)
AGENT_URL=https://csai-a2a-agent.dev.ca.opentext.com
AGENT_NAME=CSAI Agent
OAUTH2_AUTH_URL=https://otdsauth.dev.ca.opentext.com/oauth2/auth
OAUTH2_TOKEN_URL=https://otdsauth.dev.ca.opentext.com/oauth2/token

# Timeouts and polling
MCP_REQUEST_TIMEOUT_SECONDS=30
MCP_TOOL_POLL_INTERVAL_SECONDS=86400