# ── Octane MCP Server Connection ──
OCTANE_BASE_URL=http://localhost:8080
API_KEY=your-octane-api-key-here

# ── Octane Context (injected into every MCP tool call) ──
DEFAULT_SHARED_SPACE_ID=1001
DEFAULT_WORKSPACE_ID=1002

# ── Gemini Agent (optional — enables LLM-powered intent understanding) ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── A2A Wrapper Settings ──
A2A_HOST=0.0.0.0
A2A_PORT=9000

# ── Timeouts ──
MCP_REQUEST_TIMEOUT_SECONDS=30
