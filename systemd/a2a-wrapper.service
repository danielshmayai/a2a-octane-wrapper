[Unit]
Description=A2A Octane Wrapper (uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/a2a-octane-wrapper
# EnvironmentFile can point to a file with VAR=VALUE lines; do not commit secrets
EnvironmentFile=/opt/a2a-octane-wrapper/.env
ExecStart=/opt/a2a-octane-wrapper/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 9000
Restart=on-failure
RestartSec=5s
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
