# Octane MCP Server
OCTANE_BASE_URL=http://localhost:8080
API_KEY=

# Octane context (sharedSpaceId/workspaceId)
DEFAULT_SHARED_SPACE_ID=1001
DEFAULT_WORKSPACE_ID=1002

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# App binding
A2A_HOST=0.0.0.0
A2A_PORT=9000

# Timeouts and polling
MCP_REQUEST_TIMEOUT_SECONDS=30
MCP_TOOL_POLL_INTERVAL_SECONDS=86400
